<p id="notice"><%= notice %></p>

<h1>Tasks</h1>
<%= search_form_for @q do |f| %>
  <div class="row mb-3">
    <div class="col-md-3">
      <%= f.label :title_or_description_cont, "Keyword Search" %>
      <%= f.search_field :title_or_description_cont, class: "form-control", placeholder: "Title or Description" %>
    </div>

    <div class="col-md-4">
      <%= f.label :deadline_gteq, "Deadline Period" %><br>
      <%= f.date_field :deadline_gteq, class: "form-control d-inline-block w-auto" %> ~ 
      <%= f.date_field :deadline_lteq, class: "form-control d-inline-block w-auto" %>
    </div>

    <div class="col-md-4">
      <label>Status</label><br>
      <%= f.radio_button :status_eq, '', checked: true %> Not specified
      
      <%= f.radio_button :status_eq, 0 %> Todo
      <%= f.radio_button :status_eq, 1 %> Doing
      <%= f.radio_button :status_eq, 2 %> Done
    </div>

    <div class="col-md-1 d-flex align-items-end">
      <%= f.submit "Search", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Description</th>
      <th>Status</th>
      <th><%= sort_link(@q, :deadline, "Deadline") %></th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @tasks.each do |task| %>
      <tr>
        <td><%= task.title %></td>
        <td><%= task.description %></td>
        <td><%= task.status %></td>
        <td><%= task.deadline.strftime("%Y-%m-%d %H:%M") %></td>
        <td><%= link_to 'Show', task %></td>
        <td><%= link_to 'Edit', edit_task_path(task) %></td>
        <td><%= link_to 'Destroy', task, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Task', new_task_path %>
